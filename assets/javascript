// --- 2. FUNCIÓN PARA RENDERIZAR TARJETAS ---
function renderItems(category, filterText = '') {
    const container = document.getElementById(category);
    if (!container) return;

    // Obtener datos de la categoría
    let items = itemsData[category] || [];
    
    // Filtrar por texto si es necesario
    if (filterText.trim() !== '') {
        const searchTerm = filterText.toLowerCase().trim();
        items = items.filter(item => 
            item.name.toLowerCase().includes(searchTerm) || 
            (item.description && item.description.toLowerCase().includes(searchTerm))
        );
    }

    // Limpiar contenedor
    container.innerHTML = '';

    // Mostrar mensaje si no hay resultados
    if (items.length === 0) {
        container.innerHTML = `
            <div class="no-results">
                <i class="fas fa-search"></i>
                <p>No se encontraron resultados para "${filterText}"</p>
            </div>
        `;
        return;
    }

    // Generar las tarjetas
    items.forEach(item => {
        const card = document.createElement('div');
        card.className = 'item-card';
        card.innerHTML = `
            <div class="card-header">
                <div class="card-icon">
                    <i class="${item.icon || 'fa-solid fa-download'}"></i>
                </div>
                <h3>${item.name}</h3>
            </div>
            <p class="card-desc">${item.description}</p>
            <div class="card-meta">
                <span class="category-tag">${item.category || 'General'}</span>
                <a href="${item.url}" class="card-link" target="_blank">Ver más <i class="fas fa-arrow-right"></i></a>
            </div>
        `;
        container.appendChild(card);
    });
}

// --- 3. FUNCIÓN PARA CAMBIAR DE PESTAÑA ---
function openTab(tabName) {
    // Actualizar clases de los botones
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('active');
    });
    event.target.classList.add('active');

    // Ocultar todos los contenidos
    document.querySelectorAll('.tab-content').forEach(content => {
        content.style.display = 'none';
    });

    // Mostrar el contenido seleccionado
    const selectedTab = document.getElementById(tabName);
    selectedTab.style.display = 'grid'; // Asegurar que sea grid

    // Renderizar el contenido (respetando búsqueda actual)
    const searchInput = document.getElementById('search');
    renderItems(tabName, searchInput.value);
}

// --- 4. FUNCIÓN DE BÚSQUEDA (mejorada) ---
function searchItems() {
    const searchInput = document.getElementById('search');
    const searchTerm = searchInput.value;
    
    // Encontrar la pestaña activa
    const activeTab = document.querySelector('.tab-btn.active');
    if (!activeTab) return;

    // Obtener el nombre de la categoría (onclick tiene 'apps', 'games', etc)
    const tabName = activeTab.getAttribute('onclick').match(/'([^']+)'/)[1];
    
    // Renderizar la pestaña activa con el filtro
    renderItems(tabName, searchTerm);
}

// --- 5. INICIALIZACIÓN ---
document.addEventListener('DOMContentLoaded', () => {
    // Mostrar la pestaña 'apps' por defecto
    renderItems('apps', '');
    
    // Configurar el botón activo inicial
    const defaultButton = document.querySelector('.tab-btn[onclick*="apps"]');
    if (defaultButton) {
        defaultButton.classList.add('active');
    }

    // Opcional: Búsqueda en tiempo real con debounce para mejor rendimiento
    const searchInput = document.getElementById('search');
    let debounceTimer;
    searchInput.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
            searchItems();
        }, 300); // Espera 300ms después de dejar de escribir
    });
});

// Hacer funciones globales para los onclick del HTML
window.openTab = openTab;
window.searchItems = searchItems;
